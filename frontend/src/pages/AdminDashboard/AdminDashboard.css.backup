@media (max-width: 600px) {
  .admin-dashboard-main {
    flex-direction: column;
    height: auto;
    min-height: 100vh;
    padding: 0;
  }
  .admin-panel-redesigned.open {
    width: 100vw;
    min-width: 0;
    max-width: 100vw;
    border-radius: 0;
    height: auto;
    min-height: 60vh;
    box-shadow: none;
    padding: 0;
  }
  .admin-panel-header {
    padding: 18px 10px 10px 10px;
    border-radius: 0;
  }
  .admin-panel-content {
    padding: 12px 6px;
    gap: 12px;
  }
  .admin-form-section, .admin-list-section {
    padding: 12px 6px;
    border-radius: 10px;
    min-width: 0;
    max-width: 100vw;
    box-shadow: none;
  }
  .admin-list-section {
    max-height: 260px;
  }
  .admin-form-grid-extended {
    grid-template-columns: 1fr;
    gap: 8px;
    max-height: 320px;
    padding-right: 0;
  }
  .admin-form-buttons {
    grid-template-columns: 1fr;
    gap: 8px;
  }
  .admin-table-header, .admin-table-row {
    grid-template-columns: 1fr;
    font-size: 10px;
    gap: 4px;
    padding: 6px 2px;
  }
  .col-formula, .col-actions small {
    display: none;
  }
  .admin-btn, .btn-save-admin, .btn-cancel-admin {
    font-size: 13px;
    padding: 10px 8px;
    border-radius: 7px;
  }
  .admin-toggle-btn {
    width: 100vw;
    height: 44px;
    border-radius: 0;
    left: 0;
    top: 0;
    transform: none;
    font-size: 20px;
  }
  .calculator-area {
    margin-left: 0;
    padding: 0;
  }
  .calculator-hint {
    left: 10px;
    font-size: 11px;
    top: 10px;
  }
}

/* Device-specific layouts */
.admin-dashboard-main.desktop-layout {
  flex-direction: row;
  height: 100vh;
}

.admin-dashboard-main.mobile-layout {
  flex-direction: column;
  height: auto;
  min-height: 100vh;
  padding: 0;
}

.admin-dashboard-main {
  width: 100%;
  height: 100vh;
  display: flex;
  overflow: hidden;
  background: linear-gradient(135deg, #0f1419 0%, #1a1f2e 100%);
}

/* ============ Calculator Section ============ */
.admin-calculator-section {
  flex: 1;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

.admin-calculator-section .refrigerant-slider-grid {
  display: grid;
  grid-template-columns: 80px 0.8fr 1.2fr;
  grid-template-areas: "sidebar refrigerant-info input-panel";
  gap: 24px;
  min-height: calc(100vh - 56px);
  background: var(--color-bg);
  align-items: start;
  padding: 24px 24px 24px 8px;
  overflow-y: hidden;
  margin: 0;
}

.admin-calculator-section .refrigerant-slider-grid > *:nth-child(1) { grid-area: sidebar; }
.admin-calculator-section .refrigerant-slider-grid > *:nth-child(2) { grid-area: refrigerant-info; }
.admin-calculator-section .refrigerant-slider-grid > *:nth-child(3) { grid-area: input-panel; }
.admin-calculator-section .refrigerant-slider-grid > *:nth-child(4) { display: none; }

@media (max-width: 1199px) {
  .admin-calculator-section .refrigerant-slider-grid {
    grid-template-columns: 60px 0.8fr 1.2fr;
    gap: 16px;
    padding: 16px 16px 16px 8px;
  }
}

@media (max-width: 767px) {
  .admin-calculator-section .refrigerant-slider-grid {
    grid-template-columns: 1fr;
    grid-template-areas: "sidebar" "refrigerant-info" "input-panel";
    gap: 12px;
    padding: 12px;
    min-height: auto;
  }
}

/* ============ Admin Panel - Redesigned ============ */
.admin-panel-redesigned {
  position: fixed;
  right: 0;
  top: 56px;
  height: calc(100vh - 56px);
  width: 0;
  background: linear-gradient(180deg, #1a1f2e 0%, #0f1419 100%);
  backdrop-filter: blur(10px);
  box-shadow: -2px 0 20px rgba(0, 242, 255, 0.1);
  overflow-y: auto;
  z-index: 900;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border-left: 1px solid rgba(0, 242, 255, 0.2);
}

.admin-panel-redesigned.open {
  width: 480px;
  box-shadow: -4px 0 40px rgba(0, 242, 255, 0.25), 0 8px 32px rgba(0,0,0,0.18);
  border-top-left-radius: 16px;
}

/* Toggle Button - Always Visible and Clickable */
.admin-toggle-btn {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #00f2ff 0%, #0099ff 100%);
  border: none;
  border-radius: 12px 0 0 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 24px;
  box-shadow: 0 4px 15px rgba(0, 242, 255, 0.3);
  z-index: 2000;
  transition: all 0.3s ease;
  pointer-events: auto;
}

.admin-toggle-btn:hover {
  width: 65px;
  box-shadow: 0 6px 25px rgba(0, 242, 255, 0.5);
  transform: translateY(-50%) scale(1.05);
}

.admin-toggle-btn:active {
  transform: translateY(-50%) scale(0.95);
}

/* Panel Header */
.admin-panel-header {
  background: rgba(0, 242, 255, 0.12);
  padding: 32px 28px 18px 28px;
  border-bottom: 2px solid rgba(0, 242, 255, 0.18);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2px 16px rgba(0, 242, 255, 0.08);
  border-top-left-radius: 32px;
}

.admin-panel-header h1 {
  margin: 0 0 4px 0;
  font-size: 28px;
  color: #00f2ff;
  font-weight: 800;
  letter-spacing: 1.2px;
  text-shadow: 0 2px 8px rgba(0, 242, 255, 0.18);
}

.admin-panel-header p {
  margin: 0;
  font-size: 15px;
  color: #7de2fc;
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* Panel Content */
.admin-panel-content {
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Alerts */
.alert {
  padding: 12px 14px;
  border-radius: 8px;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  animation: slideInDown 0.3s ease;
}

.alert-success {
  background: rgba(34, 197, 94, 0.15);
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: #22c55e;
}

.alert-danger {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #ef4444;
}

.alert-close {
  margin-left: auto;
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  font-size: 18px;
  padding: 0;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.alert-close:hover {
  transform: scale(1.2);
}

/* Action Buttons */
.admin-action-buttons {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.admin-btn {
  flex: 1;
  padding: 10px 12px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.admin-btn-add {
  background: linear-gradient(135deg, #00f2ff 0%, #0099ff 100%);
  color: white;
  box-shadow: 0 4px 12px rgba(0, 242, 255, 0.25);
}

.admin-btn-add:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 242, 255, 0.4);
}

.admin-btn-refresh {
  background: rgba(102, 126, 234, 0.2);
  color: #667eea;
  border: 1px solid rgba(102, 126, 234, 0.3);
}

.admin-btn-refresh:hover {
  background: rgba(102, 126, 234, 0.3);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
}

.admin-btn-refresh {
  background: rgba(100, 100, 150, 0.3);
  color: #aaa;
  border: 1px solid rgba(100, 100, 150, 0.5);
}

.admin-btn-refresh:hover {
  background: rgba(100, 100, 150, 0.5);
  color: #ddd;
}

.admin-btn-close {
  background: rgba(220, 100, 100, 0.2);
  color: #dc6464;
  border: 1px solid rgba(220, 100, 100, 0.4);
  display: flex;
  align-items: center;
  gap: 6px;
}

.admin-btn-close:hover {
  background: rgba(220, 100, 100, 0.35);
  box-shadow: 0 4px 12px rgba(220, 100, 100, 0.25);
  color: #ff7f7f;
}

/* Form Section */
.admin-form-section {
  background: rgba(0, 242, 255, 0.18);
  border: 1.5px solid rgba(0, 242, 255, 0.28);
  border-radius: 18px;
  padding: 24px 20px;
  margin-bottom: 0;
  box-shadow: 0 4px 24px rgba(0, 242, 255, 0.10);
  backdrop-filter: blur(8px);
  animation: fadeInCard 0.5s;
}

.admin-form-section h3 {
  margin: 0 0 18px 0;
  color: #00f2ff;
  font-size: 22px;
  font-weight: 700;
  text-shadow: 0 2px 8px rgba(0, 242, 255, 0.18);
}

.admin-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.admin-form-grid-extended {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  max-height: 600px;
  overflow-y: auto;
  padding-right: 8px;
}

.admin-form-grid-extended::-webkit-scrollbar {
  width: 6px;
}

.admin-form-grid-extended::-webkit-scrollbar-track {
  background: rgba(0, 242, 255, 0.05);
  border-radius: 3px;
}

.admin-form-grid-extended::-webkit-scrollbar-thumb {
  background: rgba(0, 242, 255, 0.3);
  border-radius: 3px;
}

.admin-form-grid-extended::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 242, 255, 0.5);
}

.form-section-title {
  grid-column: 1 / -1;
  font-size: 14px;
  font-weight: 700;
  color: #0099ff;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 18px;
  padding-top: 10px;
  border-top: 1.5px solid rgba(0, 242, 255, 0.18);
  text-shadow: 0 2px 8px rgba(0, 242, 255, 0.10);
}

.admin-input {
  padding: 12px 16px;
  background: rgba(20, 30, 48, 0.92);
  border: 1.5px solid rgba(0, 242, 255, 0.28);
  border-radius: 10px;
  color: #fff;
  font-size: 14px;
  transition: all 0.2s ease;
  box-shadow: 0 2px 8px rgba(0, 242, 255, 0.08);
}

.admin-input:focus {
  outline: none;
  border-color: #00f2ff;
  background: rgba(0, 242, 255, 0.18);
  box-shadow: 0 0 16px rgba(0, 242, 255, 0.18);
}

.admin-input::placeholder {
  color: #666;
}

.admin-form-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 18px;
}

.btn-save-admin,
.btn-cancel-admin {
  padding: 12px 16px;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  font-size: 15px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2px 8px rgba(0, 242, 255, 0.08);
}

.btn-save-admin {
  background: linear-gradient(135deg, #00f2ff 0%, #0099ff 100%);
  color: white;
}

.btn-save-admin:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(0, 242, 255, 0.3);
}

.btn-cancel-admin {
  background: rgba(100, 100, 150, 0.2);
  color: #aaa;
  border: 1px solid rgba(100, 100, 150, 0.3);
}

.btn-cancel-admin:hover {
  background: rgba(100, 100, 150, 0.4);
  color: #ccc;
}

/* List Section */
.admin-list-section {
  background: rgba(0, 242, 255, 0.18);
  border: 1.5px solid rgba(0, 242, 255, 0.28);
  border-radius: 18px;
  padding: 24px 20px;
  max-height: 420px;
  overflow-y: auto;
  box-shadow: 0 4px 24px rgba(0, 242, 255, 0.10);
  backdrop-filter: blur(8px);
  animation: fadeInCard 0.5s;
}

.admin-list-section h3 {
  margin: 0 0 18px 0;
  color: #00f2ff;
  font-size: 22px;
  font-weight: 700;
  text-shadow: 0 2px 8px rgba(0, 242, 255, 0.18);
}

.empty-state {
  text-align: center;
  padding: 30px 10px;
  color: #666;
  font-size: 12px;
}

/* Table */
.admin-table {
  width: 100%;
  border-collapse: collapse;
}

.admin-table-header {
  display: grid;
  grid-template-columns: 1.5fr 1.5fr 0.8fr;
  gap: 8px;
  padding: 10px 8px;
  background: rgba(0, 242, 255, 0.1);
  border-bottom: 1px solid rgba(0, 242, 255, 0.2);
  font-size: 11px;
  font-weight: 600;
  color: #0099ff;
  position: sticky;
  top: 0;
}

.admin-table-row {
  display: grid;
  grid-template-columns: 1.5fr 1.5fr 0.8fr;
  gap: 8px;
  padding: 10px 8px;
  align-items: center;
  border-bottom: 1px solid rgba(0, 242, 255, 0.1);
  transition: all 0.2s ease;
}

.admin-table-row:hover {
  background: rgba(0, 242, 255, 0.08);
}

.col-name {
  font-size: 12px;
  color: #ddd;
  font-weight: 500;
}

.col-name strong {
  display: block;
  color: #00f2ff;
  margin-bottom: 2px;
}

.col-name small {
  display: block;
  font-size: 10px;
  color: #888;
}

.col-formula {
  font-size: 11px;
  color: #999;
}

.col-actions {
  display: flex;
  gap: 6px;
  justify-content: flex-end;
}

.admin-btn-small {
  width: 28px;
  height: 28px;
  padding: 0;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.admin-btn-small.edit {
  background: rgba(0, 242, 255, 0.2);
  color: #00f2ff;
}

.admin-btn-small.edit:hover {
  background: rgba(0, 242, 255, 0.4);
  transform: scale(1.1);
}

.admin-btn-small.delete {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
}

.admin-btn-small.delete:hover {
  background: rgba(239, 68, 68, 0.4);
  transform: scale(1.1);
}

/* Scrollbar */
.admin-list-section::-webkit-scrollbar {
  width: 6px;
}

.admin-list-section::-webkit-scrollbar-track {
  background: rgba(0, 242, 255, 0.05);
  border-radius: 3px;
}

.admin-list-section::-webkit-scrollbar-thumb {
  background: rgba(0, 242, 255, 0.3);
  border-radius: 3px;
}

.admin-list-section::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 242, 255, 0.5);
}

/* Calculator Area */
.calculator-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: auto;
  margin-left: 60px;
  transition: margin-left 0.4s ease;
}

.calculator-hint {
  position: absolute;
  top: 20px;
  left: 80px;
  color: rgba(0, 242, 255, 0.6);
  font-size: 13px;
  font-weight: 500;
}

/* Animations */
@keyframes fadeInCard {
  from {
    transform: translateY(20px) scale(0.98);
    opacity: 0;
  }
  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@keyframes slideInDown {
  from {
    transform: translateY(-20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* Responsive Design */
@media (max-width: 1200px) {
  .admin-panel-redesigned.open {
    width: 350px;
  }
  
  .admin-panel-header {
    padding: 20px 16px;
  }
  
  .admin-panel-content {
    padding: 16px;
  }

  .admin-form-grid {
    grid-template-columns: 1fr;
  }

  .admin-form-buttons {
    grid-template-columns: 1fr;
  }

  .admin-table-header,
  .admin-table-row {
    grid-template-columns: 1fr 0.8fr;
  }

  .col-formula {
    display: none;
  }
}

@media (max-width: 768px) {
  .admin-dashboard-container {
    flex-direction: column;
  }

  .admin-panel-redesigned.open {
    width: 100%;
    height: auto;
    max-height: 80vh;
  }

  .admin-toggle-btn {
    width: 100%;
    height: 50px;
    border-radius: 0;
    position: relative;
    left: auto;
    top: auto;
    transform: none;
  }

  .admin-toggle-btn:hover {
    width: 100%;
  }

  .calculator-area {
    margin-left: 0;
  }

  .calculator-hint {
    left: 16px;
  }
}
