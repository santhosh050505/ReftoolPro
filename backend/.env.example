# =============================================================
# RefTools-Pro Backend — Environment Variables (Render)
# =============================================================
# Copy this file, rename to .env, and fill in all real values.
# NEVER commit the real .env file to Git.

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Supabase (PostgreSQL) ─────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → Database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# If using Supabase Postgres directly via mongoose (connection string):
MONGODB_URI=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-64-char-string
JWT_EXPIRY=24h

# ── CORS ──────────────────────────────────────────────────────
# Your Vercel frontend URL (add both with and without www if needed)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Admin Setup (first deploy only, then set to false) ────────
INITIALIZE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USER=Vectarc
DEFAULT_ADMIN_PASSWORD=replace-with-strong-password
