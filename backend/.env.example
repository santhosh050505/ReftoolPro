# ================================================================
# RefTools-Pro Backend — Environment Variables Template
# ================================================================
# HOW TO USE:
#   • On Render: paste each variable into Dashboard → Environment
#   • Locally: copy this file to .env and fill in real values
# NEVER commit your real .env to Git.
# ================================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Supabase ─────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Security ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_EXPIRY=24h

# ── CORS ─────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Admin Setup (first deploy only, then set to false) ────────
INITIALIZE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USER=Vectarc
DEFAULT_ADMIN_PASSWORD=replace-with-strong-password